# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# OpenNext build output. Keep the assets/ directory itself present so the
# cloudflare vitest pool can parse wrangler.jsonc on a fresh clone (the
# directory must exist; contents don't matter for unit tests — they're
# produced by `npm run build`). Exception order matters: un-ignore parent
# dirs step by step before the file, since gitignore can't re-include a
# file whose parent dir is excluded.
/.open-next/*
!/.open-next/assets/
/.open-next/assets/*
!/.open-next/assets/.gitkeep

# wrangler files
.wrangler
.dev.vars*


!.dev.vars.example

# Playwright
/playwright-report/
/test-results/
/playwright/.cache/
/e2e/.auth/
